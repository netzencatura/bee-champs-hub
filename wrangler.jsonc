{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bee-champs-hub",
  "main": "apps/web/dist/_worker.js/index.js",
  "compatibility_date": "2026-03-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./apps/web/dist"
  },
  "observability": {
    "enabled": true
  },

  // Environment variables
  "vars": {
    "ENVIRONMENT": "production",
    "APP_URL": "https://example.com"
  },

  // KV namespace pro Astro sessions
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "12f9a5f338504b0f89fc04c538e08c74"
    }
  ],

  // D1 databáze
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bee-champs-db",
      "database_id": "fde6f351-0c01-4281-8c33-f75de8a1e934",
      "migrations_dir": "packages/db/drizzle"
    }
  ]

  // Secrets (nastavit přes `wrangler secret put`):
  // ADMIN_TOKEN, SUPERADMIN_TOKEN, RESEND_API_KEY, CF_API_TOKEN
}
